# ============================================================
# AWS - NO se requieren credenciales
# La EC2 usa Instance Profile con Semaphore_Role
# ARN: arn:aws:iam::013960975594:role/Semaphore_Role
# ============================================================

# ============================================================
# Microsoft EntraID (Azure AD) - App Registration
# ============================================================
AZURE_TENANT_ID=
OAUTH2_PROXY_CLIENT_ID=
OAUTH2_PROXY_CLIENT_SECRET=

# Group ID de EntraID para restringir acceso (Object ID del grupo en Azure AD)
# Solo usuarios que pertenezcan a este grupo podrán acceder
ENTRA_ALLOWED_GROUP_ID=

# Cookie secret (32 bytes base64)
# Generar: python3 -c 'import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())'
OAUTH2_PROXY_COOKIE_SECRET=

# ============================================================
# Dominio público (sin https://)
# ============================================================
DOMAIN=powerpipe.tu-dominio.com
